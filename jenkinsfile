pipeline {
    environment {
        registry = "abdelaaly/tp5"
        registryCredential = 'docker-hub-tocken-tp-5'
        dockerImage = ''
    }
    agent any
    stages {
        stage('Cloning Git') {
            steps {
                git branch: 'main', 
                    credentialsId: 'GITHUB-TOCKEN-TP5', 
                    url: 'https://github.com/Abdelaaly-Bouzaroual/DevOps_Jenkins_Tp5.git'
            }
        }
        stage('Building image') {
            steps {
                script {
                    // Construction de l'image avec le tag du build actuel [cite: 533]
                    dockerImage = docker.build registry + ":$BUILD_NUMBER"
                }
            }
        }
        stage('Test image') {
            steps {
                script {
                    // Simulation de tests comme demandé [cite: 535, 538]
                    echo "Tests passed"
                }
            }
        }
        stage('Publish Image') {
            steps {
                script {
                    // Publication sur Docker Hub [cite: 547, 548]
                    docker.withRegistry('', registryCredential) {
                        dockerImage.push()
                        dockerImage.push('latest')
                    }
                }
            }
        }
        stage('Deploy image') {
            steps {
                // Nettoyage et déploiement final [cite: 516, 554]
                bat "docker stop tp5-container || ver > nul"
                bat "docker rm tp5-container || ver > nul"
                bat "docker run -d -p 8081:80 --name tp5-container ${registry}:latest"
            }
        }
    }
}